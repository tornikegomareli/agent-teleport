{
  "name": "agent-teleport",
  "version": "0.3.1",
  "description": "Convert AI coding agent sessions between formats. OpenCode, Claude Code, and more.",
  "author": "Tornike Gomareli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tornikegomareli/agent-teleport.git"
  },
  "homepage": "https://github.com/tornikegomareli/agent-teleport",
  "bugs": {
    "url": "https://github.com/tornikegomareli/agent-teleport/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "session",
    "converter",
    "opencode",
    "claude-code",
